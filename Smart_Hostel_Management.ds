						ReportPermissions
						{
							tenants_by_status={"View","Edit"}
							tenants_Report={"View","Edit"}
						}
					}
				}
			}
			"Room Manager"
			{
				name = "Room Manager"
				type = Customer_Portal
				permissions = {Chat:false, Predefined:false, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "Monitor room availability and occupancy levels \n"
