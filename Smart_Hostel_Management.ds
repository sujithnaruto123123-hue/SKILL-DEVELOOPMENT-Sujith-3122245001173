				description = "Track and manage rent due dates and payment statuses \n"
				ModulePermissions
				{
					rent_records
					{
						enabled= Create,Viewall,Modifyall,Export,Tab 
						allFieldsVisible= true 
						ReportPermissions
						{
							rent_records_by_payment_mode={"View","Edit","Delete"}
							rent_records_Report={"View","Edit","Delete"}
						}
					}
				}
			}
			"Tenant"
			{
				name = "Tenant"
				type = Customer_Portal
				permissions = {Chat:false, Predefined:false, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "Register and update personal details and ID proof \n"
				ModulePermissions
				{
					complaints
					{
						enabled= Create,Tab 
						allFieldsVisible= true 
						ReportPermissions
						{
							complaints_by_issue_type={"View","Edit"}
							complaints_Report={"View","Edit"}
						}
					}
					rent_records
					{
						allFieldsVisible= true 
