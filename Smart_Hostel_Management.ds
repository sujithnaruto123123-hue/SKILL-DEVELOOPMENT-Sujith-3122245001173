 application "Smart Hostel Management"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form admin_kpis
		{
			displayname = "Admin KPIs"
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			total_revenue
			(
				displayname = "Total Revenue"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			pending_rent
			(
				displayname = "Pending Rent"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			open_complaints
			(
				type = number
				displayname = "Open Complaints"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			last_updated
			(
    			type = datetime
				displayname = "Last Updated"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form complaints
		{
			displayname = "Complaints"
			success message = "Complaint Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			tenant
			(
				type = list	
				displayname = "Tenant"
				values  = tenants.ID
    			displayformat = [tenant_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			issue_type
			(
				type = picklist
				displayname = "Issue Type"
				values = {"Plumbing","Others","Noise","Cleaning","Electrical","Security"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			description
			(
    			type = textarea
				displayname = "Description"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Closed","In Progress","Resolved","Open"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			submitted_date
			(
    			type = datetime
				displayname = "Submitted Date"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			resolved_date
			(
    			type = datetime
				displayname = "Resolved Date"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form rent_records
		{
			displayname = "Rent Records"
			success message = "Rent Record Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			tenant
			(
				type = list	
				displayname = "Tenant"
				values  = tenants.ID
    			displayformat = [tenant_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			room
			(
				type = list	
				displayname = "Room"
				values  = rooms.ID
    			displayformat = [room_number]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			due_date
			(
    			type = date
				displayname = "Due Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			amount
			(
				displayname = "Amount"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			payment_mode
			(
				type = picklist
				displayname = "Payment Mode"
				values = {"NEFT","Cash","Online","Cheque","UPI"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Partial","Paid","Overdue","Pending"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Rent Record Created","Payment Due","Rent Record Cancelled","Payment Received","Payment Overdue","Late Fee Applied","Payment Verified","Rent Record Closed","Payment Rejected"}
			}
		}
		form rooms
		{
			displayname = "Rooms"
			success message = "Room Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			room_number
			(
    			type = text
				displayname = "Room Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			occupancy
			(
				type = number
				displayname = "Occupancy"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			availability
			(
				type = picklist
				displayname = "Availability"
				values = {"Occupied","Available","Under Maintenance"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			floor
			(
    			type = text
				displayname = "Floor"
	 			row = 1
	 			column = 1   
				width = medium
			)
			rent_amount
			(
				displayname = "Rent Amount"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form tenants
		{
			displayname = "Tenants"
			success message = "Tenant Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			tenant_id
			(
    			type = autonumber
				displayname = "Tenant ID"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			first_name1
			(
    			type = text
				displayname = "First Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			last_name1
			(
    			type = text
				displayname = "Last Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			phone
			(
    			type = phonenumber
				displayname = "Phone"
	 			row = 1
	 			column = 1   
				width = medium
			)
			id_proof
			(
    			type = text
				displayname = "ID Proof"
	 			row = 1
	 			column = 1   
				width = medium
			)
			room
			(
				type = list	
				displayname = "Room"
				values  = rooms.ID
    			displayformat = [room_number]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Active","Leaving","Inactive","Reserved"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Tenant Application Submitted","ID Proof Verification Pending","Room Assignment Pending","Application Rejected","ID Proof Verified","ID Proof Rejected","Room Assigned","Room Not Available","Lease Agreement Pending","Lease Agreement Signed","Move-In Ready","Move-In Completed","Move-In Delayed","Tenant Onboarded","Move-In Failed","Tenant Active","Tenant Terminated","Tenant Renewal Pending","Tenant Offboarded"}
			}
		}
	}
	reports
	{
		list rent_records_Report
		{
			displayName = "All Rent Records"
			show all rows from rent_records    
			(
				tenant as "Tenant"
				room as "Room"
				due_date as "Due Date"
				amount as "Amount"
				(
					display = total,average,min,max	
				)
				payment_mode as "Payment Mode"
				status as "Status"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (payment_mode == "Cash")
				fields = [payment_mode]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (payment_mode == "Cheque")
				fields = [payment_mode]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (payment_mode == "Online")
				fields = [payment_mode]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban rent_records_by_payment_mode
		{
			displayName = "Payment Modes"
			show all rows from rent_records    
			(
				tenant as "Tenant"
				room as "Room"
				due_date as "Due Date"
				amount as "Amount"
				(
					display = total,average,min,max	
				)
				payment_mode as "Payment Mode"
				status as "Status"
			)
			options
			(
	 			display field = payment_mode
	 		)
		}
		list complaints_Report
		{
			displayName = "All Complaints"
			show all rows from complaints    
			(
				tenant as "Tenant"
				issue_type as "Issue Type"
				description as "Description"
				status as "Status"
				submitted_date as "Submitted Date"
				resolved_date as "Resolved Date"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Closed")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "In Progress")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "Resolved")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban complaints_by_issue_type
		{
			displayName = "Issue Types"
			show all rows from complaints    
			(
				tenant as "Tenant"
				issue_type as "Issue Type"
				description as "Description"
				status as "Status"
				submitted_date as "Submitted Date"
				resolved_date as "Resolved Date"
			)
			options
			(
	 			display field = issue_type
	 		)
		}
		list tenants_Report
		{
			displayName = "All Tenants"
			show all rows from tenants    
			(
				tenant_id as "Tenant ID"
				first_name1 as "First Name"
				last_name1 as "Last Name"
				phone as "Phone"
				id_proof as "ID Proof"
				room as "Room"
				status as "Status"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Leaving")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Reserved")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban tenants_by_status
		{
			displayName = "Statuses"
			show all rows from tenants    
			(
				tenant_id as "Tenant ID"
				first_name1 as "First Name"
				last_name1 as "Last Name"
				phone as "Phone"
				id_proof as "ID Proof"
				room as "Room"
				status as "Status"
			)
			options
			(
	 			display field = status
	 		)
		}
		list rooms_Report
		{
			displayName = "All Rooms"
			show all rows from rooms    
			(
				room_number as "Room Number"
				occupancy as "Occupancy"
				availability as "Availability"
				floor as "Floor"
				rent_amount as "Rent Amount"
				(
					display = total,average,min,max	
				)
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (availability == "Occupied")
				fields = [availability]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (availability == "Under Maintenance")
				fields = [availability]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban rooms_by_availability
		{
			displayName = "Availabilities"
			show all rows from rooms    
			(
				room_number as "Room Number"
				occupancy as "Occupancy"
				availability as "Availability"
				floor as "Floor"
				rent_amount as "Rent Amount"
				(
					display = total,average,min,max	
				)
			)
			options
			(
	 			display field = availability
	 		)
		}
		list admin_kpis_Report
		{
			displayName = "Admin KPIs Report"
			show all rows from admin_kpis    
			(
				total_revenue as "Total Revenue"
				(
					display = total,average,min,max	
				)
				pending_rent as "Pending Rent"
				(
					display = total,average,min,max	
				)
				open_complaints as "Open Complaints"
				last_updated as "Last Updated"
			)
		}
	}
	pages
	{
		page DashBoard
		{
			displayname = "Dashboard"
